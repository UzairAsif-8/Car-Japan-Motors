# ─────────────────────────────────────────────────────────────
# Car Japan Motors — Backend Environment
# Copy this file to `.env` and fill in real values.
# ─────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# PostgreSQL (Neon). Use the *pooled* connection string for the app.
# Example: postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Optional: a *direct* (non-pooled) URL used by Prisma migrations.
# If you don't have one, leave it equal to DATABASE_URL.
DIRECT_URL=

# JWT
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# Initial admin account (created by `npm run db:seed`)
ADMIN_EMAIL=admin@carjapan.pk
ADMIN_PASSWORD=carjapan

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=car-japan

# CORS — comma-separated list of allowed frontend origins.
# Localhost dev origins are always allowed automatically.
CLIENT_URL=http://localhost:5173,http://localhost:5174
